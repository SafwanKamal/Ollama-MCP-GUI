{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Ollmcp Desktop GUI",
  "version": "0.0.0",
  "identifier": "com.safwankamal.ollmcp-desktop-gui",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "bundle": {
    "icon": [
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "resources": [
      "../python-backend"
    ]
  },
  "app": {
    "windows": [
      {
        "title": "Ollmcp Desktop GUI",
        "width": 1100,
        "height": 750,
        "resizable": true,
        "transparent": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": null,
      "capabilities": ["default"]
    }
  }
}

